        },
        "bpm": {
          "type": "number",
          "example": 85
        },
        "key": {
          "type": "string",
          "example": "A Minor"
        },
        "genre": {
          "type": "string",
          "example": "Lo-Fi"
        },
        "durationSeconds": {
          "type": "number",
          "example": 185
        },
        "fileUrl": {
          "type": "string",
          "example": "https://example.com/audio.mp3"
        },
        "isPublic": {
          "type": "boolean",
          "example": true
        },
        "categoryId": {
          "type": "string",
          "example": "65f1a1a1a1a1a1a1a1a1a101"
        }
      }
    }
